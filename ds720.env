# =============================================================================
# This file contains environment variables for configuring the Docker Compose setup.
# It should not be committed to version control if it contains sensitive data.
# Instead, create a .env.example file with placeholder values.
# =============================================================================

# =============================================================================
# Database Configuration
# =============================================================================
# Password for the 'root' user within the MySQL database container.
# This is used for administrative tasks inside the container, like the healthcheck.
MYSQL_ROOT_PASSWORD="kP9sWzG7vR3tXvA2cE5bN8mY"

# The username for the application's dedicated database user.
# The backend and downloader services will use this to connect to the database.
MYSQL_USER="xyMid4nHi_KmdC7jKsNb"

# The password for the application's database user.
MYSQL_PASSWORD="sP2qL9kR1wZ6xVbN3mJ4uD7f"

# =============================================================================
# Host Path Mappings (Volumes)
# =============================================================================
# Specifies the directory on the host machine to store the MySQL database data.
# This ensures that your database data persists even if the container is removed.
DOWNLOADER_DB_DATA_PATH="/volume1/docker/Downloader Database"

# This specifies the directory on the host machine where downloaded videos
# will be stored. This path is used by docker-compose.yml to create a volume
# mapping to the '/downloads' directory inside the downloader container.
DOWNLOAD_PATH="/volume1/download/YouTube"

# This specifies the directory on the host machine where Netscape-formatted
# cookie files will be stored.
NETSCAPE_COOKIE_PATH="/volume1/download/YouTube/Cookies"

# =============================================================================
# Public Frontend Service URL
# =============================================================================
# The public-facing URL of the frontend application. This is crucial for
# NextAuth.js to construct correct redirect URLs for authentication.

# By leaving NEXTAUTH_URL commented out, NextAuth.js will dynamically determine
# the URL from request headers. This is the desired behavior for supporting
# both local and reverse-proxied access. The `trustHost: true` option in
# `auth.ts` is required for this to work securely.
# NEXTAUTH_URL="http://192.168.11.110:3000"

# =============================================================================
# Downloader Client Credentials
# =============================================================================
# These credentials are for the downloader service to authenticate with the main API.
# Replace with actual values obtained from the authentication service's /client-register endpoint.
DOWNLOADER_CLIENT_ID=""
DOWNLOADER_CLIENT_SECRET=""

# =============================================================================
# Authentication Configuration
# =============================================================================
# A secret key used by NextAuth.js for signing cookies, JWTs, and other
# security-related functions. It should be a long, random string.
# You can generate a suitable secret with the command: `openssl rand -base64 32`
AUTH_SECRET="wzc+nu6CdXyBE9bF/FGkRSw2wIR+VSnS3SASpZktMa4="

# =============================================================================
# Public URLs
# =============================================================================
# The public-facing URL of the frontend, as seen by any browser on the network.
# This is used by the backend services to configure CORS (Cross-Origin Resource Sharing).
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://192.168.11.110:3000,https://youtube.chlin.diskstation.me"

# =============================================================================
# Environment Configuration
# =============================================================================
# Specifies the environment file to load for service configuration (e.g., .env.base, .env.dev).
# This is used in docker-compose.yml to dynamically include the correct env file.
APP_ENV_FILE=".env.prod"
